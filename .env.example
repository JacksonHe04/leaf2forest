# 三个 Supabase 环境变量已经在 .env.local 中设置，本文件仅记录全部键名。
# 兼容历史变量名 SUPABASE_URL / SUPABASE_ANON_KEY / sb_publishable_* / sb_secret_*
# 推荐使用以下标准名。

# Supabase 项目 URL（公开，会暴露到浏览器）
NEXT_PUBLIC_SUPABASE_URL=

# 公开 / "publishable" key（前端使用，受 RLS 约束；当前项目未启用 RLS）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 服务端专用 key（绕过 RLS，绝不能以 NEXT_PUBLIC_ 前缀暴露，绝不能进入客户端代码）
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter API key（AI 音频转写，服务端使用，不暴露到浏览器）
OPENROUTER_API_KEY=
